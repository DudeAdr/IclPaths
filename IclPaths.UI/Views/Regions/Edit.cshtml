@model RegionViewModel
<h1 class="mt-3">Edit Region</h1>
<form method="post">
    @Html.AntiForgeryToken()
    <div class="mt-3">
        <label class="form-label">Id</label>
        <input type="text" name="Id" class="form-control" required asp-for="Id" readonly />
    </div>
    <div class="mt-3">
        <label class="form-label">Code</label>
        <input type="text" name="Code" class="form-control" required asp-for="Code" />
    </div>
    <div class="mt-3">
        <label class="form-label">Name</label>
        <input type="text" name="Name" class="form-control" required asp-for="Name" />
    </div>
    <div class="mt-3">
        <label class="form-label">Image URL</label>
        <input type="text" name="RegionImageUrl" class="form-control" required asp-for="RegionImageUrl" />
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-success">Save</button>
    </div>
</form>
