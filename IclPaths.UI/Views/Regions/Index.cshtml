
@model List<RegionViewModel>
@{
    ViewData["Title"] = "Regions";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">Regions</h1>
    <div class="d-flex justify-content-end gap-2">
        <div class="d-flex justify-content-end">
            <a class="btn btn-sm btn-primary" asp-action="Index">Refresh</a>
        </div>
        <div class="d-flex justify-content-end">
            <a class="btn btn-sm btn-success" asp-controller="Regions" asp-action="Add">Add New</a>
        </div>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No regions found.</div>
}
else
{
    <div class="row">
        @foreach (var region in Model)
        {
            <div class="col-sm-6 col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@(string.IsNullOrWhiteSpace(region.RegionImageUrl) ? Url.Content("~/images/placeholder.svg") : region.RegionImageUrl)"
                         class="card-img-top"
                         alt="@region.Name"
                         style="height:180px; object-fit:cover;"
                         loading="lazy"
                         onerror="console.warn('Image load error', this.src); this.onerror=null; this.src='@Url.Content("~/images/placeholder.svg")';" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">@region.Name</h5>
                        <p class="text-muted mb-3">Code: @region.Code</p>
                        <div class="mt-auto">
                            <a class="btn btn-outline-primary btn-sm" asp-action="Details" asp-route-id="@region.Id">Details</a>
                            <a class="btn btn-outline-secondary btn-sm" asp-controller="Regions" asp-action="Edit" asp-route-id="@region.Id">Edit</a>
                            <a class="btn btn-outline-danger btn-sm" asp-controller="Regions" asp-action="Delete" asp-route-id="@region.Id">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
