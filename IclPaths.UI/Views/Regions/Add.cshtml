@model AddRegionViewModel

<h1 class="mt-3">Add Region</h1>
<form method="post">
        <div class="mt-3">
            <label class="form-label">Code</label>
            <input type="text" name="Code" class="form-control" required asp-for="Code"/>
        </div>
    <div class="mt-3">
        <label class="form-label">Name</label>
        <input type="text" name="Name" class="form-control" required asp-for="Name" />
    </div>
    <div class="mt-3">
        <label class="form-label">Image URL</label>
        <input type="text" name="ImageUrl" class="form-control" required asp-for="RegionImageUrl" />
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-success">Add Region</button>
    </div>
</form>
