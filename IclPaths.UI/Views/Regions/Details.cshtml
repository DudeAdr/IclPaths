@model RegionViewModel

@{
    ViewData["Title"] = Model?.Name ?? "Region";
}

<div class="row">
    <div class="col-md-8">
        <div class="card mb-3">
            <img src="@(string.IsNullOrWhiteSpace(Model.RegionImageUrl) ? Url.Content("~/images/placeholder.svg") : Model.RegionImageUrl)"
                 class="card-img-top" alt="@Model.Name" style="height:420px; object-fit:cover;"
                 loading="lazy"
                 onerror="this.onerror=null; this.src='@Url.Content("~/images/placeholder.svg")';" />
            <div class="card-body">
                <h2 class="card-title">@Model.Name</h2>
                <p class="text-muted">Code: @Model.Code</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3">
            <h5>Region details</h5>
            <dl class="row">
                <dt class="col-4">Id</dt>
                <dd class="col-8">@Model.Id</dd>
                <dt class="col-4">Code</dt>
                <dd class="col-8">@Model.Code</dd>
                <dt class="col-4">Name</dt>
                <dd class="col-8">@Model.Name</dd>
            </dl>
            <a class="btn btn-secondary" asp-action="Index">Back</a>
        </div>
    </div>
</div>
